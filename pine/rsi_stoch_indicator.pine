//
// ตัวที่ 1 (Indicator Pane): overlay=false
// แสดง RSI + Stoch เปล่าๆ พร้อม Divergence signals
// ใช้คู่กับ rsi_stoch_state.pine (overlay=true) บนกราฟหลัก

//@version=5
indicator(title="RSI + Stochastic Indicator", shorttitle="RSI+Stoch Ind", overlay=false)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════

// --- RSI Settings ---
rsiLength   = input.int(14, minval=1, title="RSI Length", group="RSI Settings")
rsiSource   = input.source(close, "RSI Source", group="RSI Settings")
rsiMaLength = input.int(14, "RSI MA Length", group="RSI Settings")

// --- Stochastic Settings ---
periodK = input.int(9, title="%K Length", minval=1, group="Stoch Settings")
periodD = input.int(3, title="%D Smoothing", minval=1, group="Stoch Settings")
smoothK = input.int(3, title="%K Smoothing", minval=1, group="Stoch Settings")

// --- Zone Thresholds ---
stochOvbLevel = input.int(80, "Stoch OVB Level", group="Zone Settings")
stochOvsLevel = input.int(20, "Stoch OVS Level", group="Zone Settings")
rsiOvbLevel   = input.int(70, "RSI OVB Level", group="Zone Settings")
rsiOvsLevel   = input.int(30, "RSI OVS Level", group="Zone Settings")

// --- Divergence Settings ---
pivotLookbackL = input.int(5, "Pivot Lookback Left",  minval=1, group="Divergence Settings")
pivotLookbackR = input.int(5, "Pivot Lookback Right", minval=1, group="Divergence Settings")

// ═══════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════

rsiVal = ta.rsi(rsiSource, rsiLength)
rsiMa  = ta.sma(rsiVal, rsiMaLength)
k = ta.sma(ta.stoch(close, high, low, periodK), smoothK)
d = ta.sma(k, periodD)

// ═══════════════════════════════════════════════════════════
// ZONE STATES (สำหรับ background)
// ═══════════════════════════════════════════════════════════

stochInOvb = k > stochOvbLevel
stochInOvs = k < stochOvsLevel

// ═══════════════════════════════════════════════════════════
// DIVERGENCE ANALYSIS (Step 5)
// ═══════════════════════════════════════════════════════════

// --- Pivot Points ---
pricePivotLow  = ta.pivotlow(low, pivotLookbackL, pivotLookbackR)
rsiPivotLow    = ta.pivotlow(rsiVal, pivotLookbackL, pivotLookbackR)
pricePivotHigh = ta.pivothigh(high, pivotLookbackL, pivotLookbackR)
rsiPivotHigh   = ta.pivothigh(rsiVal, pivotLookbackL, pivotLookbackR)

// --- เก็บ Pivot Low ล่าสุด 2 ตัว ---
var float prevPriceLow     = na
var float currPriceLow     = na
var int   prevPriceLowBar  = na
var int   currPriceLowBar  = na
var float prevRsiLow       = na
var float currRsiLow       = na

if not na(pricePivotLow)
    prevPriceLow    := currPriceLow
    prevPriceLowBar := currPriceLowBar
    currPriceLow    := pricePivotLow
    currPriceLowBar := bar_index - pivotLookbackR
    prevRsiLow      := currRsiLow
    currRsiLow      := rsiPivotLow

// --- เก็บ Pivot High ล่าสุด 2 ตัว ---
var float prevPriceHigh     = na
var float currPriceHigh     = na
var int   prevPriceHighBar  = na
var int   currPriceHighBar  = na
var float prevRsiHigh       = na
var float currRsiHigh       = na

if not na(pricePivotHigh)
    prevPriceHigh    := currPriceHigh
    prevPriceHighBar := currPriceHighBar
    currPriceHigh    := pricePivotHigh
    currPriceHighBar := bar_index - pivotLookbackR
    prevRsiHigh      := currRsiHigh
    currRsiHigh      := rsiPivotHigh

// --- ตรวจจับ Divergence ---
bullishDiv = not na(pricePivotLow) and
     not na(prevPriceLow) and not na(currPriceLow) and
     not na(prevRsiLow) and not na(currRsiLow) and
     currPriceLow < prevPriceLow and
     currRsiLow > prevRsiLow

bearishDiv = not na(pricePivotHigh) and
     not na(prevPriceHigh) and not na(currPriceHigh) and
     not na(prevRsiHigh) and not na(currRsiHigh) and
     currPriceHigh > prevPriceHigh and
     currRsiHigh < prevRsiHigh

// --- แสดง Label + เส้น Divergence ---
pivotBar = bar_index - pivotLookbackR

if bullishDiv
    label.new(pivotBar, rsiVal[pivotLookbackR] - 3,
         "BULL DIV\nStoch > OVB",
         style=label.style_label_up,
         color=color.new(#00E676, 20),
         textcolor=color.white,
         size=size.small)
    line.new(prevPriceLowBar, prevRsiLow, currPriceLowBar, currRsiLow,
         color=color.new(#00E676, 20), width=2, style=line.style_solid)

if bearishDiv
    label.new(pivotBar, rsiVal[pivotLookbackR] + 3,
         "BEAR DIV\nStoch > OVS",
         style=label.style_label_down,
         color=color.new(#FF5252, 20),
         textcolor=color.white,
         size=size.small)
    line.new(prevPriceHighBar, prevRsiHigh, currPriceHighBar, currRsiHigh,
         color=color.new(#FF5252, 20), width=2, style=line.style_solid)

// ═══════════════════════════════════════════════════════════
// PLOTTING
// ═══════════════════════════════════════════════════════════

// --- Levels ---
h_stoch_upper = hline(stochOvbLevel, "Stoch Upper", color=color.gray)
h_stoch_lower = hline(stochOvsLevel, "Stoch Lower", color=color.gray)
h_rsi_upper   = hline(rsiOvbLevel, "RSI Upper", color=color.new(color.orange, 30), linestyle=hline.style_dashed)
h_rsi_lower   = hline(rsiOvsLevel, "RSI Lower", color=color.new(color.orange, 30), linestyle=hline.style_dashed)
h_mid         = hline(50, "Middle Band", color=color.new(color.gray, 70), linestyle=hline.style_dotted)
fill(h_stoch_upper, h_stoch_lower, color=color.new(#2962FF, 95))

// --- Stochastic Lines ---
plot(k, title="Stoch %K", color=color.new(#00E676, 20), linewidth=1)
plot(d, title="Stoch %D", color=color.new(#FF5252, 20), linewidth=1)

// --- RSI Lines ---
plot(rsiVal, title="RSI", color=color.white, linewidth=2)
plot(rsiMa, title="RSI MA", color=color.yellow, linewidth=1)

// --- Zone Background ---
bgcolor(stochInOvb ? color.new(color.red, 90) : na, title="Stoch OVB Zone")
bgcolor(stochInOvs ? color.new(color.green, 90) : na, title="Stoch OVS Zone")
